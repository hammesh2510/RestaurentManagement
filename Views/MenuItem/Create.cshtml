@model RestaurantManagementSystem.Models.MenuItem
@{
    ViewData["Title"] = "Add Catalog Dish";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-burger me-2 text-indigo"></i>Add Catalog Dish</h1>
        <p class="text-muted m-0">Add a food dish or beverage to the menu.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to Catalog
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #ffffff;">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold text-slate-700">Dish Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Chicken Burger, Paneer Tikka" required />
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label fw-semibold text-slate-700">Category</label>
                        @if (ViewBag.Categories == null || !((SelectList)ViewBag.Categories).Any())
                        {
                            <div class="alert alert-warning border-0 p-3 mb-2" style="background-color: #fffbeb; border-radius: 10px;">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="fa-solid fa-triangle-exclamation text-warning me-2 fa-lg"></i>
                                    <span class="fw-bold" style="color: #b45309; font-size: 0.9rem;">No Categories Setup Yet</span>
                                </div>
                                <p class="small mb-2 text-slate-600" style="font-size: 0.8rem; line-height: 1.4;">You must create at least one category before adding food catalog items.</p>
                                <a href="/Category/Index" class="btn btn-warning btn-sm fw-bold px-3 py-1.5 text-white" style="background-color: #d97706; border: none; border-radius: 6px; font-size: 0.78rem;">
                                    <i class="fa-solid fa-plus me-1"></i>Go to Category Setup
                                </a>
                            </div>
                            <select asp-for="CategoryId" class="form-select form-control d-none">
                                <option value="">-- No Categories --</option>
                            </select>
                        }
                        else
                        {
                            <select asp-for="CategoryId" class="form-select form-control" asp-items="ViewBag.Categories" required>
                                <option value="">-- Select Category --</option>
                            </select>
                        }
                        <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold text-slate-700"></label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input asp-for="Price" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" required />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsVeg" class="form-check-input" type="checkbox" />
                                <label asp-for="IsVeg" class="form-check-label fw-semibold text-slate-700">🌱 Vegetarian</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsRecommended" class="form-check-input" type="checkbox" />
                                <label asp-for="IsRecommended" class="form-check-label fw-semibold text-slate-700">⭐ Recommended</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IsAvailable" class="form-check-label fw-semibold text-slate-700 me-2">Currently Stocked / In Stock?</label>
                        <div class="form-check form-switch d-inline-block align-middle">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                        </div>
                        <span asp-validation-for="IsAvailable" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold text-slate-700"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional brief ingredients or details description..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid mt-4">
                        @if (ViewBag.Categories == null || !((SelectList)ViewBag.Categories).Any())
                        {
                            <button type="button" class="btn btn-secondary py-2.5 fw-semibold" style="border-radius: 8px;" disabled>
                                <i class="fa-solid fa-ban me-2"></i>Save Dish (Category Required)
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary py-2.5 fw-semibold" style="border-radius: 8px;">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Save Dish
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
