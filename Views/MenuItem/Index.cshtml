@model IEnumerable<RestaurantManagementSystem.Models.MenuItem>
@{
    ViewData["Title"] = "Menu Items Catalog";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-burger me-2 text-indigo"></i>Menu Catalog</h1>
        <p class="text-muted m-0">Configure food dishes, prices, categories, and availability indicators.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-primary px-4 py-2" style="border-radius: 8px;">
            <i class="fa-solid fa-plus me-2"></i>Add Menu Item
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #ffffff;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold" style="background-color: #f8fafc;">
                    <tr>
                        <th class="ps-4">Meal details</th>
                        <th>Category</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">VEG?</th>
                        <th class="text-center">REC?</th>
                        <th class="text-center">Availability</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-slate-800">@item.Name</span>
                                <div class="text-muted small text-truncate" style="max-width: 250px;">@item.Description</div>
                            </td>
                            <td><span class="badge bg-light text-dark px-2 py-1 border">@item.Category?.Name</span></td>
                            <td class="text-end fw-bold text-slate-800">₹@item.Price.ToString("F2")</td>
                            <td class="text-center">
                                @if (item.IsVeg)
                                {
                                    <span class="text-success"><i class="fa-solid fa-circle-check fa-lg"></i></span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="fa-solid fa-times-circle fa-lg"></i></span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.IsRecommended)
                                {
                                    <span class="text-warning"><i class="fa-solid fa-star fa-lg"></i></span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="fa-regular fa-star fa-lg"></i></span>
                                }
                            </td>
                            <td class="text-center">
                                @Html.AntiForgeryToken()
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" role="switch" id="switch-@item.Id" checked="@item.IsAvailable" onclick="toggleStock(@item.Id)" />
                                </div>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="text-primary me-2.5" title="Edit Item"><i class="fa-solid fa-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this menu item?');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link text-danger p-0" title="Delete Item" style="border: none; background: none;">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-cookie-bite fa-3x text-light-custom mb-3" style="color: #e2e8f0;"></i>
                                <h5>No menu items logged. Click 'Add Menu Item' to start.</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStock(itemId) {
            $.ajax({
                url: '/MenuItem/ToggleAvailability',
                type: 'POST',
                data: {
                    id: itemId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (res) {
                    if (!res.success) {
                        alert(res.message || "Failed to update item availability.");
                        // Re-sync switch status in DOM
                        let sw = $('#switch-' + itemId);
                        sw.prop('checked', !sw.prop('checked'));
                    }
                },
                error: function () {
                    alert("A transmission error occurred.");
                    let sw = $('#switch-' + itemId);
                    sw.prop('checked', !sw.prop('checked'));
                }
            });
        }
    </script>
}
