@model RestaurantManagementSystem.Models.RestaurantTable
@{
    ViewData["Title"] = "Add New Table";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-chair me-2 text-indigo"></i>Add New Table</h1>
        <p class="text-muted m-0">Add a physical table to the restaurant floor.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #ffffff;">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="TableNumber" class="form-label fw-semibold text-slate-700"></label>
                        <input asp-for="TableNumber" class="form-control" placeholder="e.g. Table 1, Room A-1" required />
                        <span asp-validation-for="TableNumber" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold text-slate-700"></label>
                        <input asp-for="Capacity" type="number" class="form-control" min="1" max="100" required />
                        <span asp-validation-for="Capacity" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold text-slate-700"></label>
                        <select asp-for="Status" class="form-select form-control" asp-items="Html.GetEnumSelectList<RestaurantManagementSystem.Models.TableStatus>()"></select>
                        <span asp-validation-for="Status" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary py-2.5 fw-semibold" style="border-radius: 8px;">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Save Table
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
