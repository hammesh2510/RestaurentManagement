@model IEnumerable<RestaurantManagementSystem.Models.RestaurantTable>
@{
    ViewData["Title"] = "Table Management";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-chair me-2 text-indigo"></i>Table Management</h1>
        <p class="text-muted m-0">Setup restaurant floor layout and physical tables.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-primary px-4 py-2" style="border-radius: 8px;">
            <i class="fa-solid fa-plus me-2"></i>Add New Table
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius: 15px; background-color: #ffffff;">
    <div class="card-body p-4">
        <div class="row g-4">
            @foreach (var table in Model)
            {
                string statusColor = table.Status switch
                {
                    RestaurantManagementSystem.Models.TableStatus.Available => "bg-success",
                    RestaurantManagementSystem.Models.TableStatus.Occupied => "bg-danger",
                    RestaurantManagementSystem.Models.TableStatus.Reserved => "bg-warning text-dark",
                    RestaurantManagementSystem.Models.TableStatus.Cleaning => "bg-info",
                    _ => "bg-secondary"
                };

                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card border border-light h-100 p-3 shadow-hover" style="border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge @statusColor px-2.5 py-1.5 font-weight-600" style="font-size: 0.75rem;">
                                @table.Status
                            </span>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="border: none; background: none;">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                    <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@table.Id"><i class="fa-solid fa-pencil text-muted me-2"></i>Edit</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Delete" asp-route-id="@table.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this table?');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger"><i class="fa-solid fa-trash me-2"></i>Delete</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="text-center my-3">
                            <div class="d-inline-flex align-items-center justify-content-center bg-light text-slate-700 rounded-circle mb-2" style="width: 60px; height: 60px;">
                                <i class="fa-solid fa-chair fa-2xl"></i>
                            </div>
                            <h5 class="fw-bold m-0 text-slate-800">@table.TableNumber</h5>
                            <small class="text-muted"><i class="fa-solid fa-users me-1 text-slate-400"></i>Capacity: @table.Capacity Seats</small>
                        </div>

                        <!-- Status manual override buttons -->
                        <div class="mt-3 pt-2 border-top">
                            <div class="row g-1">
                                @if (table.Status == RestaurantManagementSystem.Models.TableStatus.Cleaning)
                                {
                                    <div class="col-12">
                                        <button onclick="updateTableStatus(@table.Id, 'Available')" class="btn btn-sm btn-outline-success w-100 font-weight-500 py-1.5" style="border-radius: 6px;">
                                            <i class="fa-solid fa-check me-1"></i>Mark Available
                                        </button>
                                    </div>
                                }
                                else if (table.Status == RestaurantManagementSystem.Models.TableStatus.Available)
                                {
                                    <div class="col-12">
                                        <button onclick="updateTableStatus(@table.Id, 'Reserved')" class="btn btn-sm btn-outline-warning w-100 font-weight-500 py-1.5 text-dark" style="border-radius: 6px;">
                                            <i class="fa-solid fa-bookmark me-1"></i>Mark Reserved
                                        </button>
                                    </div>
                                }
                                else if (table.Status == RestaurantManagementSystem.Models.TableStatus.Reserved)
                                {
                                    <div class="col-6">
                                        <button onclick="updateTableStatus(@table.Id, 'Available')" class="btn btn-sm btn-outline-success w-100 font-weight-500 py-1.5" style="border-radius: 6px; font-size: 0.78rem;">
                                            <i class="fa-solid fa-check me-1"></i>Release
                                        </button>
                                    </div>
                                    <div class="col-6">
                                        <a href="/Order/WaiterPOS?tableId=@table.Id" class="btn btn-sm btn-outline-primary w-100 font-weight-500 py-1.5" style="border-radius: 6px; font-size: 0.78rem;">
                                            <i class="fa-solid fa-cart-plus me-1"></i>Seat
                                        </a>
                                    </div>
                                }
                                else // Occupied
                                {
                                    <div class="col-12">
                                        <a href="/Manager/TableActivities" class="btn btn-sm btn-outline-danger w-100 font-weight-500 py-1.5" style="border-radius: 6px;">
                                            <i class="fa-solid fa-eye me-1"></i>View Active Bill
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateTableStatus(tableId, statusName) {
            showSpinner();
            $.ajax({
                url: '/Table/ToggleStatus',
                type: 'POST',
                data: {
                    id: tableId,
                    status: statusName,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (res) {
                    hideSpinner();
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message || "Failed to update table status.");
                    }
                },
                error: function () {
                    hideSpinner();
                    alert("A communication error occurred.");
                }
            });
        }
    </script>
}

<style>
    .shadow-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(15, 23, 42, 0.08) !important;
    }
</style>
