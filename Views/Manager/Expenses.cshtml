@model IEnumerable<RestaurantManagementSystem.Models.Expense>
@{
    ViewData["Title"] = "Expenses Ledger";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-receipt me-2 text-indigo"></i>Expenses Ledger</h1>
        <p class="text-muted m-0">Log and verify operational business costs (wages, utility bills, rent, etc.).</p>
    </div>
    <div class="col-auto">
        <a asp-action="CreateExpense" class="btn btn-primary px-4 py-2" style="border-radius: 8px;">
            <i class="fa-solid fa-plus me-2"></i>Log New Expense
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #ffffff;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold" style="background-color: #f8fafc;">
                    <tr>
                        <th class="ps-4">Expense details</th>
                        <th>Category</th>
                        <th>Date logged</th>
                        <th class="text-end">Amount</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exp in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-slate-800">@exp.ExpenseName</div>
                                <div class="text-muted small">@exp.Description</div>
                            </td>
                            <td><span class="badge bg-light text-dark px-2.5 py-1.5 border">@exp.Category</span></td>
                            <td class="text-muted small">@exp.Date.ToString("MM/dd/yyyy")</td>
                            <td class="text-end fw-bold text-danger">-₹@exp.Amount.ToString("N2")</td>
                            <td class="text-center">
                                <form asp-action="DeleteExpense" asp-route-id="@exp.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this expense entry?');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link text-danger p-0" title="Delete entry" style="border: none; background: none;">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-receipt fa-3x text-light-custom mb-3" style="color: #e2e8f0;"></i>
                                <h5>No expenses found. Click 'Log New Expense' to begin.</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
