@model IEnumerable<RestaurantManagementSystem.Models.Employee>
@{
    ViewData["Title"] = "Staff Directory";
    var roles = ViewBag.StaffRoles as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-users-gear me-2 text-indigo"></i>Staff Directory</h1>
        <p class="text-muted m-0">Review, authorize, and manage system access credentials for your restaurant's team members.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px; background-color: #d1e7dd; color: #0f5132;">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px; background-color: #fff3cd; color: #664d03;">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px; background-color: #f8d7da; color: #842029;">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #ffffff;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold" style="background-color: #f8fafc; border-bottom: 1px solid #edf2f7;">
                    <tr>
                        <th class="ps-4" style="padding-top: 15px; padding-bottom: 15px;">Employee Details</th>
                        <th>Phone Number</th>
                        <th>System Role</th>
                        <th>Status</th>
                        <th class="text-center" style="width: 150px;">App Access</th>
                        <th class="text-center" style="width: 100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        var role = roles.ContainsKey(emp.UserId ?? "") ? roles[emp.UserId!] : "Staff";
                        var initials = (emp.FirstName.Length > 0 ? emp.FirstName.Substring(0, 1) : "") + (emp.LastName.Length > 0 ? emp.LastName.Substring(0, 1) : "");
                        if (string.IsNullOrEmpty(initials)) initials = "U";
                        initials = initials.ToUpper();

                        // Pick color based on role
                        var roleBadgeClass = role switch
                        {
                            "Waiter" => "bg-light-blue text-blue-custom border border-blue-accent",
                            "Chef" => "bg-light-orange text-orange-custom border border-orange-accent",
                            "Cashier" => "bg-light-green text-green-custom border border-green-accent",
                            _ => "bg-light text-dark border"
                        };

                        var statusBadgeId = $"status-badge-{emp.UserId}";
                        var statusSwitchId = $"status-switch-{emp.UserId}";

                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="d-flex align-items-center justify-content-center fw-bold text-white rounded-circle shadow-sm" 
                                         style="width: 40px; height: 40px; font-size: 0.95rem; background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);">
                                        @initials
                                    </div>
                                    <div>
                                        <div class="fw-bold text-slate-800" style="font-size: 0.925rem;">@emp.FullName</div>
                                        <div class="text-muted small">@emp.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-slate-600 font-monospace small">@emp.Phone</td>
                            <td>
                                <span class="badge @roleBadgeClass px-2.5 py-1.5 fw-semibold" style="border-radius: 6px; font-size: 0.75rem;">
                                    @role
                                </span>
                            </td>
                            <td>
                                <span id="@statusBadgeId" class="badge @(emp.IsActive ? "bg-success-light text-success" : "bg-danger-light text-danger") px-2.5 py-1.5 fw-semibold" 
                                      style="border-radius: 6px; font-size: 0.75rem;">
                                    @(emp.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" role="switch" id="@statusSwitchId" @(emp.IsActive ? "checked" : "")
                                           style="width: 2.2rem; height: 1.155rem; cursor: pointer;"
                                           onclick="ajaxToggleStatus('@emp.UserId', this)" />
                                </div>
                            </td>
                            <td class="text-center">
                                <form asp-action="DeleteStaff" asp-route-id="@emp.UserId" method="post" 
                                      onsubmit="return confirm('Are you sure you want to permanently delete @emp.FullName\'s credentials?\nIf they have placed past orders, their account will be deactivated instead to preserve billing history.');" 
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link text-danger p-0" title="Delete staff member" style="border: none; background: none;">
                                        <i class="fa-solid fa-trash-can" style="font-size: 1.05rem;"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-users fa-3x text-light-custom mb-3" style="color: #cbd5e1;"></i>
                                <h5 class="fw-semibold text-slate-700">No staff accounts found</h5>
                                <p class="text-muted small">New Waiters or Chefs must register using your email address as referral key to appear here.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Styling elements alignment */
    .bg-light-blue { background-color: #e0f2fe; }
    .text-blue-custom { color: #0369a1; }
    .border-blue-accent { border-color: #bae6fd !important; }

    .bg-light-orange { background-color: #ffedd5; }
    .text-orange-custom { color: #c2410c; }
    .border-orange-accent { border-color: #fed7aa !important; }

    .bg-light-green { background-color: #dcfce7; }
    .text-green-custom { color: #15803d; }
    .border-green-accent { border-color: #bbf7d0 !important; }

    .bg-success-light { background-color: #d1e7dd; color: #0f5132; }
    .bg-danger-light { background-color: #f8d7da; color: #842029; }
</style>

@section Scripts {
    <script>
        function ajaxToggleStatus(userId, checkbox) {
            // Prevent fast multiple clicks
            $(checkbox).attr('disabled', true);

            // Fetch anti-forgery token from layout
            const token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '/Manager/ToggleStaffStatus',
                type: 'POST',
                data: {
                    id: userId,
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    $(checkbox).attr('disabled', false);
                    if (res.success) {
                        const badge = $('#status-badge-' + userId);
                        if (res.isActive) {
                            badge.removeClass('bg-danger-light text-danger').addClass('bg-success-light text-success').text('Active');
                            checkbox.checked = true;
                        } else {
                            badge.removeClass('bg-success-light text-success').addClass('bg-danger-light text-danger').text('Inactive');
                            checkbox.checked = false;
                        }
                    } else {
                        // Revert check state on failure
                        checkbox.checked = !checkbox.checked;
                        alert(res.message || "Failed to update staff status.");
                    }
                },
                error: function () {
                    $(checkbox).attr('disabled', false);
                    checkbox.checked = !checkbox.checked;
                    alert("A communications error occurred while updating status.");
                }
            });
        }
    </script>
}
