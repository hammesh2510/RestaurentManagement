@model RestaurantManagementSystem.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="h3 m-0 fw-bold text-slate-800"><i class="fa-solid fa-id-card me-2 text-indigo"></i>My Profile</h1>
        <p class="text-muted m-0">View or update your personal account credentials and phone number.</p>
    </div>
</div>

<div class="row justify-content-start">
    <div class="col-lg-6 col-md-8 col-12">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px; background-color: #d1e7dd; color: #0f5132;">
                <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #ffffff;">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <!-- Email Field (Disabled) -->
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-secondary fw-semibold small"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="fa-solid fa-envelope"></i></span>
                            <input asp-for="Email" class="form-control bg-light border-start-0 text-muted" readonly disabled />
                        </div>
                    </div>

                    <!-- System Role (Disabled) -->
                    <div class="mb-4">
                        <label asp-for="Role" class="form-label text-secondary fw-semibold small"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="fa-solid fa-user-shield"></i></span>
                            <input asp-for="Role" class="form-control bg-light border-start-0 text-muted" readonly disabled />
                        </div>
                    </div>

                    <!-- Full Name Field -->
                    <div class="mb-4">
                        <label asp-for="FullName" class="form-label text-secondary fw-semibold small">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0 bg-transparent text-secondary"><i class="fa-solid fa-user"></i></span>
                            <input asp-for="FullName" class="form-control border-start-0 input-with-icon" placeholder="Full name address" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Phone Number Field -->
                    <div class="mb-4">
                        <label asp-for="Phone" class="form-label text-secondary fw-semibold small">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0 bg-transparent text-secondary"><i class="fa-solid fa-phone"></i></span>
                            <input asp-for="Phone" class="form-control border-start-0 input-with-icon" placeholder="Phone number" required />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary py-2.5 fw-bold" style="border-radius: 8px; font-size: 0.95rem;">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Save Profile Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .input-with-icon:focus {
        border-color: #ced4da;
        box-shadow: none;
    }
</style>
