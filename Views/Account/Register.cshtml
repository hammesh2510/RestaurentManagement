@model RestaurantManagementSystem.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Restaurant Management System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            background-color: #0f172a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: #f1f5f9;
            margin: 0;
            padding: 40px 0;
        }

        .login-container {
            width: 100%;
            max-width: 500px;
            padding: 20px;
        }

        .login-card {
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 10px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -4px rgba(0, 0, 0, 0.3);
            padding: 40px 30px;
        }

        .brand-logo {
            font-size: 1.8rem;
            color: #ffffff;
            font-weight: 700;
            text-align: center;
            margin-bottom: 6px;
        }

        .brand-subtitle {
            color: #94a3b8;
            font-size: 0.875rem;
            text-align: center;
            margin-bottom: 30px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .form-control, .form-select {
            background-color: #0f172a;
            border: 1px solid #475569;
            color: #ffffff;
            border-radius: 6px;
            padding: 10px 14px;
            font-size: 0.95rem;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }

        .form-control:focus, .form-select:focus {
            background-color: #0f172a;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.255);
            color: #ffffff;
        }

        .form-select option {
            background-color: #1e293b;
            color: #ffffff;
        }

        .form-label {
            color: #cbd5e1;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .btn-primary {
            background-color: #2563eb;
            border: 1px solid #2563eb;
            border-radius: 6px;
            padding: 10px 20px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.15s ease;
        }

        .btn-primary:hover {
            background-color: #1d4ed8;
            border-color: #1d4ed8;
        }

        .btn-primary:active {
            background-color: #1e40af;
            border-color: #1e40af;
        }

        .text-link-custom {
            color: #60a5fa;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .text-link-custom:hover {
            color: #93c5fd;
            text-decoration: underline;
        }

        .validation-summary-errors {
            background-color: #7f1d1d;
            border: 1px solid #991b1b;
            border-radius: 6px;
            padding: 12px;
            margin-bottom: 20px;
            color: #fca5a5;
            font-size: 0.875rem;
        }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 20px;
        }

        .input-group-text-custom {
            background-color: #334155;
            border: 1px solid #475569;
            color: #94a3b8;
            border-radius: 6px 0 0 6px;
            width: 46px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .input-with-icon {
            border-radius: 0 6px 6px 0 !important;
        }

        .text-danger-custom {
            color: #fca5a5 !important;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="brand-logo">
                <i class="fa-solid fa-utensils me-2"></i>RESTAURANT
            </div>
            <div class="brand-subtitle">Create Account</div>

            <form asp-action="Register" asp-controller="Account" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                }

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-user"></i></span>
                        <input asp-for="FullName" class="form-control input-with-icon" placeholder="Firstname Lastname" autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control input-with-icon" placeholder="name@restaurant.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-phone"></i></span>
                        <input asp-for="Phone" class="form-control input-with-icon" placeholder="+1234567890" autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-briefcase"></i></span>
                        <select asp-for="Role" class="form-select input-with-icon">
                            <option value="">-- Choose Position --</option>
                            <option value="Manager">Manager</option>
                            <option value="Waiter">Waiter</option>
                            <option value="Chef">Chef</option>
                            <option value="Cashier">Cashier</option>
                        </select>
                    </div>
                    <span asp-validation-for="Role" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <div class="mb-3" id="manager-group" style="display: none;">
                    <label asp-for="SelectedManagerId" class="form-label">Manager's Referral Email</label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="SelectedManagerId" class="form-control input-with-icon" type="email" placeholder="manager@restaurant.com" />
                    </div>
                    <span asp-validation-for="SelectedManagerId" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" class="form-control input-with-icon" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control input-with-icon" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger-custom small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">
                    <i class="fa-solid fa-user-plus me-2"></i>Sign Up
                </button>
            </form>

            <div class="text-center mt-3">
                <span class="text-secondary small">Already have an account? </span>
                <a asp-action="Login" asp-controller="Account" class="text-link-custom fw-semibold">Sign In</a>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function () {
            function toggleManagerDropdown() {
                var selectedRole = $('#Role').val();
                if (selectedRole && selectedRole !== 'Manager') {
                    $('#manager-group').slideDown();
                } else {
                    $('#manager-group').slideUp();
                }
            }

            $('#Role').change(toggleManagerDropdown);
            toggleManagerDropdown();
        });
    </script>
</body>
</html>

