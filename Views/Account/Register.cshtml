@model RestaurantManagementSystem.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Restaurant Management System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #311042 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            color: #f8fafc;
            overflow-x: hidden;
            padding: 40px 0;
        }

        .login-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 500px;
            padding: 15px;
        }

        .login-card {
            background: rgba(30, 41, 59, 0.45);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            padding: 40px 35px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .login-card:hover {
            box-shadow: 0 15px 35px rgba(124, 58, 237, 0.2);
            transform: translateY(-2px);
        }

        .brand-logo {
            font-size: 2.5rem;
            background: linear-gradient(45deg, #818cf8, #c084fc, #fb7185);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            letter-spacing: -1px;
            text-align: center;
            margin-bottom: 5px;
        }

        .brand-subtitle {
            color: #94a3b8;
            font-size: 0.875rem;
            text-align: center;
            margin-bottom: 35px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .form-control, .form-select {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #f8fafc;
            border-radius: 10px;
            padding: 12px 16px;
            transition: all 0.2s ease;
        }

        .form-control:focus, .form-select:focus {
            background: rgba(15, 23, 42, 0.85);
            border-color: #818cf8;
            box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.25);
            color: #f8fafc;
        }

        .form-select option {
            background: #1e293b;
            color: #f8fafc;
        }

        .form-label {
            color: #cbd5e1;
            font-size: 0.875rem;
            font-weight: 500;
            margin-left: 2px;
            margin-bottom: 6px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            border: none;
            border-radius: 10px;
            padding: 12px 20px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
            box-shadow: 0 4px 15px rgba(79, 70, 229, 0.4);
            transform: translateY(-1px);
        }

        .text-muted-custom {
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.2s ease;
        }

        .text-muted-custom:hover {
            color: #818cf8;
        }

        .validation-summary-errors {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.4);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 25px;
            color: #fca5a5;
            font-size: 0.875rem;
        }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 20px;
        }

        .input-group-text-custom {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #94a3b8;
            border-radius: 10px 0 0 10px;
            width: 46px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .input-with-icon {
            border-radius: 0 10px 10px 0 !important;
        }

        .glow-sphere-1 {
            position: absolute;
            top: -10%;
            left: -10%;
            width: 300px;
            height: 300px;
            background: rgba(99, 102, 241, 0.15);
            border-radius: 50%;
            filter: blur(80px);
            z-index: 1;
        }

        .glow-sphere-2 {
            position: absolute;
            bottom: -10%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(217, 70, 239, 0.12);
            border-radius: 50%;
            filter: blur(80px);
            z-index: 1;
        }
    </style>
</head>
<body>
    <div class="glow-sphere-1"></div>
    <div class="glow-sphere-2"></div>

    <div class="login-container">
        <div class="login-card">
            <div class="brand-logo">
                <i class="fa-solid fa-utensils me-2"></i>RESTAURANT
            </div>
            <div class="brand-subtitle">Create Account</div>

            <form asp-action="Register" asp-controller="Account" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                }

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-user"></i></span>
                        <input asp-for="FullName" class="form-control input-with-icon" placeholder="Firstname Lastname" autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control input-with-icon" placeholder="name@restaurant.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-phone"></i></span>
                        <input asp-for="Phone" class="form-control input-with-icon" placeholder="+1234567890" autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-briefcase"></i></span>
                        <select asp-for="Role" class="form-select input-with-icon">
                            <option value="">-- Choose Position --</option>
                            <option value="Manager">Manager</option>
                            <option value="Waiter">Waiter</option>
                            <option value="Chef">Chef</option>
                            <option value="Cashier">Cashier</option>
                        </select>
                    </div>
                    <span asp-validation-for="Role" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <div class="mb-3" id="manager-group" style="display: none;">
                    <label asp-for="SelectedManagerId" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-hotel"></i></span>
                        <select asp-for="SelectedManagerId" class="form-select input-with-icon" asp-items="@(ViewBag.Managers != null ? new SelectList(ViewBag.Managers, "Id", "Email") : null)">
                            <option value="">-- Choose Manager / Location --</option>
                        </select>
                    </div>
                    <span asp-validation-for="SelectedManagerId" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" class="form-control input-with-icon" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-custom"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control input-with-icon" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block" style="color: #fca5a5 !important;"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">
                    <i class="fa-solid fa-user-plus me-2"></i>Sign Up
                </button>
            </form>

            <div class="text-center mt-3">
                <span class="text-muted" style="font-size: 0.9rem;">Already have an account? </span>
                <a asp-action="Login" asp-controller="Account" class="text-muted-custom fw-semibold">Sign In</a>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function () {
            function toggleManagerDropdown() {
                var selectedRole = $('#Role').val();
                if (selectedRole && selectedRole !== 'Manager') {
                    $('#manager-group').slideDown();
                } else {
                    $('#manager-group').slideUp();
                }
            }

            $('#Role').change(toggleManagerDropdown);
            toggleManagerDropdown();
        });
    </script>
</body>
</html>
