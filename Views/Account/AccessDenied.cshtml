@{
    Layout = "_Layout";
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg" style="border-radius: 15px; background: rgba(30, 41, 59, 0.05);">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="fa-solid fa-triangle-exclamation text-warning" style="font-size: 5rem;"></i>
                    </div>
                    <h1 class="display-5 fw-bold text-danger mb-3">Access Denied</h1>
                    <p class="lead text-muted mb-4">
                        You do not have the required permissions to view this resource. 
                        Please contact your system administrator if you believe this is in error.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary px-4 py-2">
                            <i class="fa-solid fa-home me-2"></i>Go to Dashboard
                        </a>
                        <a asp-action="Login" asp-controller="Account" class="btn btn-primary px-4 py-2">
                            <i class="fa-solid fa-sign-in-alt me-2"></i>Login as Different User
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
